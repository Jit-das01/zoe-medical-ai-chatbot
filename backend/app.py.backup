"""
MediBot - AI Medical Chatbot Backend
FastAPI + OpenAI + LangChain
"""

from fastapi import FastAPI, HTTPException
from fastapi.middleware.cors import CORSMiddleware
from pydantic import BaseModel
from typing import List, Optional
import openai
import os
from datetime import datetime

app = FastAPI(title="MediBot API")

# CORS middleware
app.add_middleware(
    CORSMiddleware,
    allow_origins=["*"],
    allow_credentials=True,
    allow_methods=["*"],
    allow_headers=["*"],
)

# OpenAI API key (set this in environment variables)
openai.api_key = os.getenv("OPENAI_API_KEY", "your-api-key-here")

# System prompt for medical chatbot
SYSTEM_PROMPT = """You are MediBot, a helpful medical information assistant. Your role is to:

1. Listen to users' health concerns and symptoms
2. Provide general medical information and education
3. Suggest when to seek professional medical care
4. Detect "red flag" symptoms that need immediate attention

CRITICAL RULES:
- You are NOT a doctor and cannot diagnose or prescribe
- Always recommend consulting a healthcare professional for diagnosis
- For emergencies (chest pain, difficulty breathing, severe bleeding, stroke symptoms), immediately advise calling emergency services
- Be empathetic, clear, and supportive
- Ask clarifying questions when needed
- Provide evidence-based information

RED FLAG SYMPTOMS (require immediate medical attention):
- Chest pain or pressure
- Difficulty breathing
- Sudden severe headache
- Sudden numbness or weakness
- Uncontrolled bleeding
- Severe abdominal pain
- High fever with confusion
- Suicidal thoughts

Format your responses with:
- Clear explanations
- Bullet points for symptoms/recommendations
- Empathetic tone
- Always end with "⚠️ Disclaimer: This is general information only. Please consult a healthcare professional for proper diagnosis and treatment."
"""

# Chat history storage (in-memory for MVP, use database in production)
chat_sessions = {}

class Message(BaseModel):
    role: str
    content: str
    timestamp: Optional[str] = None

class ChatRequest(BaseModel):
    message: str
    session_id: Optional[str] = None
    user_info: Optional[dict] = None

class ChatResponse(BaseModel):
    response: str
    session_id: str
    is_emergency: bool
    suggested_actions: Optional[List[str]] = None
    timestamp: str

def detect_emergency(message: str) -> bool:
    """Detect emergency keywords in user message"""
    emergency_keywords = [
        "chest pain", "heart attack", "can't breathe", "difficulty breathing",
        "severe bleeding", "bleeding heavily", "stroke", "suicidal", 
        "kill myself", "unconscious", "severe headache", "can't move"
    ]
    
    message_lower = message.lower()
    return any(keyword in message_lower for keyword in emergency_keywords)

def get_chat_history(session_id: str) -> List[dict]:
    """Retrieve chat history for a session"""
    if session_id not in chat_sessions:
        chat_sessions[session_id] = []
    return chat_sessions[session_id]

def save_message(session_id: str, role: str, content: str):
    """Save message to chat history"""
    if session_id not in chat_sessions:
        chat_sessions[session_id] = []
    
    chat_sessions[session_id].append({
        "role": role,
        "content": content,
        "timestamp": datetime.now().isoformat()
    })

@app.get("/")
def root():
    return {
        "message": "MediBot API is running",
        "version": "1.0.0",
        "status": "healthy"
    }

@app.get("/api/health")
def health_check():
    return {
        "status": "healthy",
        "timestamp": datetime.now().isoformat()
    }

@app.post("/api/chat", response_model=ChatResponse)
async def chat(request: ChatRequest):
    """Main chat endpoint"""
    try:
        # Generate session ID if not provided
        session_id = request.session_id or f"session_{datetime.now().timestamp()}"
        
        # Check for emergency
        is_emergency = detect_emergency(request.message)
        
        # Get chat history
        history = get_chat_history(session_id)
        
        # Prepare messages for OpenAI
        messages = [{"role": "system", "content": SYSTEM_PROMPT}]
        
        # Add history (last 10 messages to keep context manageable)
        for msg in history[-10:]:
            messages.append({
                "role": msg["role"],
                "content": msg["content"]
            })
        
        # Add current user message
        messages.append({
            "role": "user",
            "content": request.message
        })
        
        # Call OpenAI API
        response = openai.ChatCompletion.create(
            model="gpt-3.5-turbo",
            messages=messages,
            temperature=0.7,
            max_tokens=500
        )
        
        bot_response = response.choices[0].message.content
        
        # Save messages to history
        save_message(session_id, "user", request.message)
        save_message(session_id, "assistant", bot_response)
        
        # Generate suggested actions
        suggested_actions = []
        if is_emergency:
            suggested_actions = [
                "🚨 Call emergency services (911/108) immediately",
                "Do not drive yourself to the hospital",
                "Stay calm and wait for help"
            ]
        else:
            suggested_actions = [
                "Consult a healthcare professional",
                "Monitor your symptoms",
                "Keep a symptom diary"
            ]
        
        return ChatResponse(
            response=bot_response,
            session_id=session_id,
            is_emergency=is_emergency,
            suggested_actions=suggested_actions,
            timestamp=datetime.now().isoformat()
        )
    
    except Exception as e:
        raise HTTPException(status_code=500, detail=str(e))

@app.get("/api/history/{session_id}")
def get_history(session_id: str):
    """Get chat history for a session"""
    history = get_chat_history(session_id)
    return {
        "session_id": session_id,
        "message_count": len(history),
        "messages": history
    }

@app.delete("/api/history/{session_id}")
def clear_history(session_id: str):
    """Clear chat history for a session"""
    if session_id in chat_sessions:
        del chat_sessions[session_id]
    return {"message": "History cleared", "session_id": session_id}

@app.get("/api/sessions")
def list_sessions():
    """List all active sessions"""
    return {
        "total_sessions": len(chat_sessions),
        "sessions": [
            {
                "session_id": sid,
                "message_count": len(messages),
                "last_activity": messages[-1]["timestamp"] if messages else None
            }
            for sid, messages in chat_sessions.items()
        ]
    }

if __name__ == "__main__":
    import uvicorn
    print("\n🤖 MediBot API starting...")
    print("📍 API will be available at: http://localhost:8000")
    print("📚 Docs available at: http://localhost:8000/docs")
    print("\n⚠️  Remember to set OPENAI_API_KEY environment variable!\n")
    uvicorn.run(app, host="0.0.0.0", port=8000)
